---
layout: layouts/base.njk
title: Posts
permalink: /
---
<div class="post-list">
  {% for post in collections.posts %}
    <article class="post-card">
      <h2 class="post-card-title">
        <a href="{{ post.url }}">{{ post.data.title }}</a>
      </h2>
      <div class="post-card-meta">
        <time datetime="{{ post.data.date | isoDate }}">{{ post.data.date | readableDate }}</time>
        {% if post.data.tags and post.data.tags.length %}
          <span class="post-card-tags">
            {% for tag in post.data.tags %}
              <a href="/tags/{{ tag }}/">{{ tag }}</a>{% if not loop.last %}, {% endif %}
            {% endfor %}
          </span>
        {% endif %}
      </div>
      {% if post.data.excerpt %}
        <p class="post-card-excerpt">{{ post.data.excerpt }}</p>
      {% endif %}
    </article>
  {% endfor %}
</div>
